<!DOCTYPE html>
<html>

<head>
  <title>Taco Recipes</title>
  <link rel="stylesheet" type="text/css" href="/styles/main.css">
</head>

<body>
  <h1>Taco Town 🌮</h1>

  <form action="/recipe" method="POST" class="buttons">
    <button type="submit" value="chicken" name="choice">🍗</button>
    <button type="submit" value="beef" name="choice">🥩</button>
    <button type="submit" value="fish" name="choice">🐟</button>
  </form>
  <div id="recipeContainer" class="hidden">
    <%if(locals.taco){%>
      <h3>Ingredients:</h3>

      <!-- - <li>Protein name, protein preparation</li>
      -      <li>Salsa name</li>
      -      <li>Every other topping</li> -->
      <ul id="ingredientsList">
        <li>Protein: <%=taco.ingredients.protein.name%></li> 
        <li> Preperation: <%= taco.ingredients.protein.preparation%></li> 
      <li> Salsa: <%=taco.ingredients.salsa.name%></li>
      <%taco.ingredients.toppings.forEach(topping => {%>
        <li>Topping Name: <%=topping.name %> made up of <%=topping.ingredients%> with quantity of <%= topping.quantity%> </li>
        <%})%>
    
      </ul>
  <%}else{%>
      <h2>Pick your favourite taco ingredient 👆</h2>
    <%}%>
    


  </div>
</body>

</html>